<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ui.EmployeesController"
      spacing="20"
      styleClass="inventory-container">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Text text="Employee Management" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField" promptText="Search employees..." prefWidth="250" styleClass="search-field"/>
        <Button text="+ Add Employee" onAction="#handleAddEmployee" styleClass="btn-primary-small"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-border-color: transparent;">
        <FlowPane fx:id="employeeGrid" hgap="18" vgap="18"
                  style="-fx-padding: 4 2 10 2;"/>
    </ScrollPane>
</VBox>
