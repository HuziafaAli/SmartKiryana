<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<StackPane xmlns="http://javafx.com/javafx/8.0.171"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ui.LoginController"
           stylesheets="ui/style.css"
           styleClass="login-root">

    <!-- Background Decorative Elements (Optional, could be added in CSS) -->
    <VBox alignment="CENTER" spacing="0">
        <Region fx:id="bgCircle1" styleClass="bg-glow-1"/>
    </VBox>

    <VBox alignment="CENTER">
        <VBox styleClass="login-card" alignment="CENTER" maxWidth="450">
            <padding>
                <Insets top="50" right="50" bottom="50" left="50"/>
            </padding>

            <!-- Header -->
            <VBox alignment="CENTER" spacing="10">
                <Text text="SmartKiryana" styleClass="login-brand-title"/>
                <Text text="Log in to your account" styleClass="text-muted,text-sm"/>
            </VBox>

            <!-- Form -->
            <VBox spacing="25" alignment="CENTER_LEFT" style="-fx-padding: 40 0 0 0;">
                <VBox spacing="8">
                    <Label text="USERNAME" styleClass="login-field-label"/>
                    <TextField fx:id="usernameField"
                               promptText="Enter your username"
                               styleClass="login-input"/>
                </VBox>

                <VBox spacing="8">
                    <Label text="PASSWORD" styleClass="login-field-label"/>
                    <PasswordField fx:id="passwordField"
                                   promptText="Enter your password"
                                   styleClass="login-input"/>
                </VBox>

                <Button onAction="#handleLogin"
                        text="SIGN IN"
                        maxWidth="Infinity"
                        styleClass="login-submit-btn"/>

                <Label fx:id="statusLabel" text="" styleClass="status-label" wrapText="true"/>
            </VBox>

            <Region prefHeight="40"/>
            <Text text="© 2024 SmartKiryana Management" styleClass="text-muted,text-xs"/>
        </VBox>
    </VBox>
</StackPane>