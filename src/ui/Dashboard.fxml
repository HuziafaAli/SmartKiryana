<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<BorderPane xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ui.DashboardController"
            stylesheets="ui/style.css"
            styleClass="dashboard-container">

    <!-- SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" prefWidth="230" spacing="5">
            <padding>
                <Insets top="30" right="15" bottom="15" left="15"/>
            </padding>

            <!-- Logo Area -->
            <VBox alignment="CENTER" spacing="8" style="-fx-padding: 0 0 30 0;">
                <ImageView pickOnBounds="true" preserveRatio="true" fitWidth="60">
                    <Image url="@assets/logo.png"/>
                </ImageView>
                <Text text="SmartKiryana" styleClass="sidebar-brand"/>
            </VBox>

            <!-- Navigation Links -->
            <Button fx:id="navDashboard" text="Dashboard" onAction="#showDashboardHome" maxWidth="Infinity" styleClass="nav-button,nav-button-active"/>
            <Button fx:id="navPOS" text="Billing (POS)" onAction="#showPOS" maxWidth="Infinity" styleClass="nav-button"/>
            <Button fx:id="navInventory" text="Inventory" onAction="#showInventory" maxWidth="Infinity" styleClass="nav-button"/>
            <Button fx:id="navSales" text="Sales" onAction="#showSales" maxWidth="Infinity" styleClass="nav-button"/>
            <Button fx:id="navEmployees" text="Employees" onAction="#showEmployees" maxWidth="Infinity" styleClass="nav-button"/>
            <Button fx:id="navReports" text="Reports" onAction="#showReports" maxWidth="Infinity" styleClass="nav-button"/>
            <Button fx:id="navSalesTarget" text="Sales Target" onAction="#showSalesTarget" maxWidth="Infinity" styleClass="nav-button"/>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- User Info & Logout -->
            <VBox spacing="5" styleClass="user-profile">
                <Label fx:id="userNameLabel" text="Admin User" styleClass="user-name"/>
                <Label fx:id="userRoleLabel" text="Admin" styleClass="user-role"/>
                <Button text="Logout" onAction="#handleLogout" maxWidth="Infinity" styleClass="btn-logout-sidebar"/>
            </VBox>
        </VBox>
    </left>

    <!-- MAIN CONTENT AREA -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area"/>
    </center>

</BorderPane>
