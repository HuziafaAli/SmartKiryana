<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ui.InventoryController"
      styleClass="inventory-container">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 0 0 20 0;">
        <Text text="Inventory Management" styleClass="page-title"/>
    </HBox>

    <TabPane fx:id="inventoryTabs" tabClosingPolicy="UNAVAILABLE"
             VBox.vgrow="ALWAYS" styleClass="inventory-tabs">

        <!-- PRODUCTS TAB -->
        <Tab text="Products">
            <VBox spacing="15" style="-fx-padding: 15 0 0 0;">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <TextField fx:id="productSearchField"
                               promptText="Search by name or barcode..."
                               prefWidth="260" styleClass="search-field"/>
                    <ComboBox fx:id="categoryFilter"
                              promptText="All Categories"
                              prefWidth="170" styleClass="dark-combo"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="+ Add Product"
                            onAction="#handleAddProduct"
                            styleClass="btn-primary-small"/>
                </HBox>
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <FlowPane fx:id="productGrid" hgap="18" vgap="18"
                              style="-fx-padding: 4 2 10 2;"/>
                </ScrollPane>
            </VBox>
        </Tab>

        <!-- CATEGORIES TAB -->
        <Tab text="Categories">
            <VBox spacing="15" style="-fx-padding: 15 0 0 0;">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <TextField fx:id="categorySearchField"
                               promptText="Search categories..."
                               prefWidth="260" styleClass="search-field"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="+ Add Category"
                            onAction="#handleAddCategory"
                            styleClass="btn-primary-small"/>
                </HBox>
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <FlowPane fx:id="categoryGrid" hgap="18" vgap="18"
                              style="-fx-padding: 4 2 10 2;"/>
                </ScrollPane>
            </VBox>
        </Tab>

    </TabPane>
</VBox>
