<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ui.ReportsController"
      spacing="20"
      styleClass="inventory-container">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Text fx:id="pageTitle" text="Employee Performance" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="employeeSelector" promptText="Select Employee" prefWidth="200" styleClass="dark-combo" visible="false"/>
        <ComboBox fx:id="monthSelector" promptText="Month" prefWidth="120" styleClass="dark-combo"/>
        <ComboBox fx:id="yearSelector" promptText="Year" prefWidth="100" styleClass="dark-combo"/>
        <Button text="Generate" onAction="#handleGenerate" styleClass="btn-primary-small"/>
    </HBox>

    <!-- Employee Info Card -->
    <HBox spacing="20" alignment="CENTER_LEFT" styleClass="section-panel">
        <VBox spacing="3" alignment="CENTER">
            <Label fx:id="empNameLabel" text="" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Label fx:id="empRoleLabel" text="" styleClass="text-muted,text-sm"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <VBox spacing="3" alignment="CENTER">
            <Label text="Total Sales" styleClass="text-muted,text-sm"/>
            <Label fx:id="totalSalesLabel" text="Rs. 0" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        </VBox>
        <VBox spacing="3" alignment="CENTER">
            <Label text="Transactions" styleClass="text-muted,text-sm"/>
            <Label fx:id="transactionsLabel" text="0" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        </VBox>
        <VBox spacing="3" alignment="CENTER">
            <Label text="Average Bill Value" styleClass="text-muted,text-sm"/>
            <Label fx:id="avgBillLabel" text="Rs. 0" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        </VBox>
    </HBox>

    <!-- Target Progress + Details -->
    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <!-- Target Progress Circle -->
        <VBox styleClass="section-panel" prefWidth="300" spacing="15" alignment="CENTER">
            <Text text="Target Progress" styleClass="section-title"/>
            <VBox styleClass="progress-circle" alignment="CENTER" spacing="2">
                <Label fx:id="progressPercent" text="0%" styleClass="progress-percent"/>
            </VBox>
            <HBox alignment="CENTER" spacing="5">
                <Label fx:id="salesTargetInfo" text="" styleClass="text-muted,text-sm"/>
            </HBox>
            <VBox spacing="5" alignment="CENTER">
                <Label text="Sales Target (Rs. )" styleClass="text-muted,text-sm"/>
                <Label fx:id="targetAmountLabel" text="Rs. 0" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
            </VBox>
        </VBox>

        <!-- Performance Details -->
        <VBox styleClass="section-panel" HBox.hgrow="ALWAYS" spacing="15">
            <Text text="Performance Details" styleClass="section-title"/>

            <HBox spacing="15">
                <VBox styleClass="stat-card,stat-card-blue" HBox.hgrow="ALWAYS" style="-fx-min-height: 80; -fx-padding: 15;">
                    <Label text="Achievement" styleClass="stat-card-title"/>
                    <Label fx:id="achievementLabel" text="0%" styleClass="stat-card-value" style="-fx-font-size: 20px;"/>
                </VBox>
                <VBox styleClass="stat-card,stat-card-green" HBox.hgrow="ALWAYS" style="-fx-min-height: 80; -fx-padding: 15;">
                    <Label text="Bonus" styleClass="stat-card-title"/>
                    <Label fx:id="bonusLabel" text="Rs. 0" styleClass="stat-card-value" style="-fx-font-size: 20px;"/>
                </VBox>
            </HBox>

            <VBox spacing="8" VBox.vgrow="ALWAYS">
                <Text text="Sales Summary" styleClass="section-title"/>
                <Label fx:id="summaryLabel" text="Generate a report to view performance details." styleClass="text-muted" wrapText="true"/>
            </VBox>
        </VBox>
    </HBox>
</VBox>
