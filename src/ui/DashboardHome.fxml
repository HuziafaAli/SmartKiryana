<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ui.DashboardHomeController"
      spacing="20"
      styleClass="inventory-container">

    <padding>
        <Insets top="15" right="20" bottom="15" left="20"/>
    </padding>

    <!-- Page Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Text text="Dashboard" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="welcomeLabel" text="Welcome, Admin" styleClass="text-muted"/>
    </HBox>

    <!-- Stat Cards Row -->
    <HBox spacing="20" alignment="CENTER">
        <VBox styleClass="stat-card,stat-card-blue" HBox.hgrow="ALWAYS">
            <Label text="Today's Sales" styleClass="stat-card-title"/>
            <Label fx:id="todaySalesLabel" text="Rs. 0" styleClass="stat-card-value"/>
            <Label fx:id="todaySalesChange" text="" styleClass="stat-card-subtitle"/>
        </VBox>
        <VBox styleClass="stat-card,stat-card-green" HBox.hgrow="ALWAYS">
            <Label text="Monthly Revenue" styleClass="stat-card-title"/>
            <Label fx:id="monthlyRevenueLabel" text="Rs. 0" styleClass="stat-card-value"/>
            <Label fx:id="monthlyRevenueChange" text="" styleClass="stat-card-subtitle"/>
        </VBox>
        <VBox styleClass="stat-card,stat-card-red" HBox.hgrow="ALWAYS">
            <Label text="Stock Alerts Items" styleClass="stat-card-title"/>
            <Label fx:id="lowStockLabel" text="0" styleClass="stat-card-value"/>
        </VBox>
        <VBox styleClass="stat-card,stat-card-purple" HBox.hgrow="ALWAYS">
            <Label text="Total Products" styleClass="stat-card-title"/>
            <Label fx:id="totalProductsLabel" text="0" styleClass="stat-card-value"/>
            <Label text="In inventory" styleClass="stat-card-subtitle"/>
        </VBox>
    </HBox>

    <!-- Main Content Area: Left Column (Sales & Tables), Right Column (Insights) -->
    <HBox spacing="20" VBox.vgrow="ALWAYS">
        
        <!-- LEFT COLUMN -->
        <VBox spacing="20" HBox.hgrow="ALWAYS">
            <!-- Sales Overview Panel -->
            <VBox styleClass="section-panel" spacing="15" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Text text="Sales Overview" styleClass="section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="This Week" styleClass="text-muted,text-sm"/>
                </HBox>
                <VBox fx:id="salesChartArea" VBox.vgrow="ALWAYS" alignment="CENTER" style="-fx-min-height: 250;">
                    <Label text="Sales chart will appear here" styleClass="text-muted"/>
                </VBox>
            </VBox>

            <!-- Recent Transactions -->
            <VBox styleClass="section-panel" spacing="10">
                <HBox alignment="CENTER_LEFT">
                    <Text text="Recent Transactions" styleClass="section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>
                <TableView fx:id="recentBillsTable" prefHeight="220" styleClass="modern-table">
                    <columns>
                        <TableColumn fx:id="colBillId" text="Bill #" prefWidth="80"/>
                        <TableColumn fx:id="colBillDate" text="Date" prefWidth="160"/>
                        <TableColumn fx:id="colBillAmount" text="Amount" prefWidth="140"/>
                        <TableColumn fx:id="colBillCashier" text="Cashier" prefWidth="180"/>
                    </columns>
                </TableView>
            </VBox>
        </VBox>

        <!-- RIGHT COLUMN -->
        <VBox spacing="20" prefWidth="320">
            <!-- Performance Summary / Top Selling -->
            <VBox styleClass="section-panel" spacing="15">
                <HBox alignment="CENTER_LEFT">
                    <Text text="Performance Summary" styleClass="section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="This Month" styleClass="text-muted,text-sm"/>
                </HBox>
                <VBox fx:id="topProductsList" spacing="12"/>
            </VBox>

            <!-- Stock Alerts -->
            <VBox styleClass="section-panel" spacing="15" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Text text="Stock Alerts" styleClass="section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="alertCountLabel" text="" styleClass="badge-warning"/>
                </HBox>
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <VBox fx:id="alertsList" spacing="8"/>
                </ScrollPane>
            </VBox>
        </VBox>
    </HBox>

</VBox>
