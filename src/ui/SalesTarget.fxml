<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ui.SalesTargetController"
      spacing="10"
      styleClass="pos-container">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <VBox spacing="3">
            <Text text="Sales Target" styleClass="page-title"/>
            <Text text="Assign monthly goals and track employee progress." styleClass="page-subtitle"/>
        </VBox>
    </HBox>

    <HBox spacing="15" VBox.vgrow="ALWAYS">
        <VBox prefWidth="430" spacing="12" styleClass="target-form-panel">
            <VBox spacing="3">
                <Text text="Set Monthly Target" styleClass="section-title"/>
                <Label text="Choose an employee, period, and target amount." styleClass="text-muted"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Employee" styleClass="field-label"/>
                <ComboBox fx:id="empSelector" promptText="Select Employee" maxWidth="Infinity" styleClass="dark-combo"/>
            </VBox>

            <HBox spacing="10">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Month" styleClass="field-label"/>
                    <ComboBox fx:id="monthSelector" promptText="Month" maxWidth="Infinity" styleClass="dark-combo"/>
                </VBox>
                <VBox spacing="4" prefWidth="130">
                    <Label text="Year" styleClass="field-label"/>
                    <ComboBox fx:id="yearSelector" promptText="Year" maxWidth="Infinity" styleClass="dark-combo"/>
                </VBox>
            </HBox>

            <VBox spacing="4">
                <Label text="Target Amount" styleClass="field-label"/>
                <TextField fx:id="targetField" promptText="Enter target amount..." styleClass="dark-input"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="6" styleClass="target-note-card">
                <Label text="Target Rule" styleClass="inv-card-field-label"/>
                <Label text="Bonus is calculated when achieved sales exceed the assigned target." styleClass="target-note-text"/>
            </VBox>

            <Button text="Set Target" onAction="#handleSetTarget" maxWidth="Infinity" styleClass="btn-pay"/>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" spacing="12">
            <HBox spacing="12">
                <VBox styleClass="target-hero-card" HBox.hgrow="ALWAYS">
                    <Label text="Selected Employee" styleClass="inv-card-field-label"/>
                    <Label fx:id="selectedEmpLabel" text="Select an employee" styleClass="target-employee-name"/>
                    <Label fx:id="periodLabel" text="Current period" styleClass="text-muted"/>
                </VBox>
                <VBox styleClass="target-hero-card" HBox.hgrow="ALWAYS">
                    <Label text="Current Target" styleClass="inv-card-field-label"/>
                    <Label fx:id="currentTargetLabel" text="Rs. 0" styleClass="target-amount-main"/>
                    <Label fx:id="progressInfoLabel" text="No target set" styleClass="text-muted"/>
                </VBox>
            </HBox>

            <HBox spacing="12" VBox.vgrow="ALWAYS">
                <VBox styleClass="target-progress-panel" alignment="CENTER" spacing="10" HBox.hgrow="ALWAYS">
                    <Text text="Achievement" styleClass="section-title"/>
                    <VBox fx:id="progressRing" styleClass="progress-circle" alignment="CENTER" spacing="2">
                        <Label fx:id="progressLabel" text="0%" styleClass="progress-percent"/>
                        <Label text="completed" styleClass="progress-label"/>
                    </VBox>
                    <Label fx:id="achievementMessageLabel" text="Select an employee to view progress." styleClass="target-message"/>
                </VBox>

                <VBox styleClass="target-progress-panel" spacing="10" prefWidth="330">
                    <Text text="Progress Details" styleClass="section-title"/>

                    <VBox spacing="6" styleClass="target-detail-card">
                        <Label text="Achieved Sales" styleClass="inv-card-field-label"/>
                        <Label fx:id="achievedLabel" text="Rs. 0" styleClass="target-detail-value"/>
                    </VBox>

                    <VBox spacing="6" styleClass="target-detail-card">
                        <Label text="Remaining" styleClass="inv-card-field-label"/>
                        <Label fx:id="remainingLabel" text="Rs. 0" styleClass="target-detail-warning"/>
                    </VBox>

                    <VBox spacing="6" styleClass="target-detail-card">
                        <Label text="Bonus Estimate" styleClass="inv-card-field-label"/>
                        <Label fx:id="bonusLabel" text="Rs. 0" styleClass="target-detail-bonus"/>
                    </VBox>
                </VBox>
            </HBox>
        </VBox>
    </HBox>

    <VBox spacing="10" styleClass="target-history-panel" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT">
            <Text text="Previous Targets" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="historyCountLabel" text="Select an employee" styleClass="text-muted"/>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <FlowPane fx:id="targetHistoryFlow" hgap="14" vgap="14" style="-fx-padding: 2;"/>
        </ScrollPane>
    </VBox>
</VBox>
