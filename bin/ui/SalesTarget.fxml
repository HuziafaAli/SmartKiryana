<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ui.SalesTargetController"
      spacing="10"
      styleClass="pos-container">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <VBox spacing="3">
            <Text text="Sales Target" styleClass="page-title"/>
            <Text text="Assign monthly goals and track employee progress." styleClass="page-subtitle"/>
        </VBox>
    </HBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <!-- LEFT COLUMN: Profile, Target Summary, and Assignment Form -->
        <VBox prefWidth="380" spacing="15">
            <!-- Selected Employee Card -->
            <VBox styleClass="target-hero-card">
                <Label text="Selected Employee" styleClass="inv-card-field-label"/>
                <Label fx:id="selectedEmpLabel" text="Select an employee" styleClass="target-employee-name"/>
                <Label fx:id="periodLabel" text="Current period" styleClass="text-muted"/>
            </VBox>

            <!-- Current Target Card -->
            <VBox styleClass="target-hero-card">
                <Label text="Current Target" styleClass="inv-card-field-label"/>
                <Label fx:id="currentTargetLabel" text="Rs. 0" styleClass="target-amount-main"/>
                <Label fx:id="progressInfoLabel" text="No target set" styleClass="text-muted"/>
            </VBox>

            <!-- Set Monthly Target Form -->
            <VBox spacing="12" styleClass="target-form-panel" VBox.vgrow="ALWAYS">
                <VBox spacing="3">
                    <Text text="Set Monthly Target" styleClass="section-title"/>
                    <Label text="Assign a new goal for the period." styleClass="text-muted"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Employee" styleClass="field-label"/>
                    <ComboBox fx:id="empSelector" promptText="Select Employee" maxWidth="Infinity" styleClass="dark-combo"/>
                </VBox>

                <HBox spacing="10">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Month" styleClass="field-label"/>
                        <ComboBox fx:id="monthSelector" promptText="Month" maxWidth="Infinity" styleClass="dark-combo"/>
                    </VBox>
                    <VBox spacing="4" prefWidth="110">
                        <Label text="Year" styleClass="field-label"/>
                        <ComboBox fx:id="yearSelector" promptText="Year" maxWidth="Infinity" styleClass="dark-combo"/>
                    </VBox>
                </HBox>

                <VBox spacing="4">
                    <Label text="Target Amount" styleClass="field-label"/>
                    <TextField fx:id="targetField" promptText="Enter target amount..." styleClass="dark-input"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <Button text="Set Target" onAction="#handleSetTarget" maxWidth="Infinity" styleClass="btn-pay"/>
            </VBox>
        </VBox>

        <!-- RIGHT COLUMN: Full History Dashboard -->
        <VBox HBox.hgrow="ALWAYS" spacing="15" styleClass="target-history-panel">
            <HBox alignment="CENTER_LEFT">
                <Text text="Previous Targets History" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="historyCountLabel" text="Select an employee" styleClass="text-muted"/>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-border-color: transparent;">
                <FlowPane fx:id="targetHistoryFlow" hgap="20" vgap="20" style="-fx-padding: 5;"/>
            </ScrollPane>
        </VBox>
    </HBox>

    <!-- Hidden elements for controller compatibility -->
    <HBox visible="false" managed="false">
        <VBox fx:id="progressRing"/>
        <Label fx:id="progressLabel"/>
        <Label fx:id="achievementMessageLabel"/>
        <Label fx:id="achievedLabel"/>
        <Label fx:id="remainingLabel"/>
        <Label fx:id="bonusLabel"/>
    </HBox>
</VBox>
