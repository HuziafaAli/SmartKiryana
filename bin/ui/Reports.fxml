<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ui.ReportsController"
      styleClass="inventory-container">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 0 0 10 0;">
        <Text fx:id="pageTitle" text="Reports &amp; Analytics" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="monthSelector" promptText="Month" prefWidth="120" styleClass="dark-combo"/>
        <ComboBox fx:id="yearSelector" promptText="Year" prefWidth="100" styleClass="dark-combo"/>
        <Button text="Generate" onAction="#handleGenerate" styleClass="btn-primary-small"/>
        <Button text="Export PDF" onAction="#handleExportPDF" styleClass="btn-primary-small" style="-fx-background-color: #ef4444;"/>
    </HBox>

    <TabPane fx:id="reportTabs" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS" styleClass="inventory-tabs">
        <!-- PERFORMANCE REPORT TAB -->
        <Tab text="Performance Report">
            <VBox spacing="20" style="-fx-padding: 15 0 0 0;">
                <!-- Employee Selection (Admin only) -->
                <HBox fx:id="employeeSelectionBox" alignment="CENTER_LEFT" spacing="10">
                    <Label text="Select Employee:" styleClass="text-muted"/>
                    <ComboBox fx:id="employeeSelector" promptText="Choose Employee" prefWidth="200" styleClass="dark-combo"/>
                </HBox>

                <!-- Employee Info Card -->
                <HBox spacing="20" alignment="CENTER_LEFT" styleClass="section-panel">
                    <VBox spacing="3" alignment="CENTER">
                        <Label fx:id="empNameLabel" text="" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                        <Label fx:id="empRoleLabel" text="" styleClass="text-muted,text-sm"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <VBox spacing="3" alignment="CENTER">
                        <Label text="Total Sales" styleClass="text-muted,text-sm"/>
                        <Label fx:id="totalSalesLabel" text="Rs. 0" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox spacing="3" alignment="CENTER">
                        <Label text="Transactions" styleClass="text-muted,text-sm"/>
                        <Label fx:id="transactionsLabel" text="0" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox spacing="3" alignment="CENTER">
                        <Label text="Average Bill" styleClass="text-muted,text-sm"/>
                        <Label fx:id="avgBillLabel" text="Rs. 0" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                    </VBox>
                </HBox>

                <!-- Target Progress + Details -->
                <HBox spacing="20" VBox.vgrow="ALWAYS">
                    <!-- Target Progress Circle -->
                    <VBox styleClass="section-panel" prefWidth="300" spacing="15" alignment="CENTER">
                        <Text text="Target Progress" styleClass="section-title"/>
                        <VBox styleClass="progress-circle" alignment="CENTER" spacing="2">
                            <Label fx:id="progressPercent" text="0%" styleClass="progress-percent"/>
                        </VBox>
                        <HBox alignment="CENTER" spacing="5">
                            <Label fx:id="salesTargetInfo" text="" styleClass="text-muted,text-sm"/>
                        </HBox>
                        <VBox spacing="5" alignment="CENTER">
                            <Label text="Sales Target" styleClass="text-muted,text-sm"/>
                            <Label fx:id="targetAmountLabel" text="Rs. 0" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                        </VBox>
                    </VBox>

                    <!-- Performance Details -->
                    <VBox styleClass="section-panel" HBox.hgrow="ALWAYS" spacing="20">
                        <Text text="Performance Insights" styleClass="section-title"/>
                        
                        <HBox spacing="15">
                            <VBox styleClass="stat-card,stat-card-blue" HBox.hgrow="ALWAYS" spacing="5">
                                <Label text="Achievement" styleClass="stat-card-title"/>
                                <Label fx:id="achievementLabel" text="0%" styleClass="stat-card-value"/>
                            </VBox>
                            <VBox styleClass="stat-card,stat-card-green" HBox.hgrow="ALWAYS" spacing="5">
                                <Label text="Bonus Earned" styleClass="stat-card-title"/>
                                <Label fx:id="bonusLabel" text="Rs. 0" styleClass="stat-card-value"/>
                            </VBox>
                            <VBox styleClass="stat-card,stat-card-purple" HBox.hgrow="ALWAYS" spacing="5">
                                <Label text="Peak Sale" styleClass="stat-card-title"/>
                                <Label fx:id="peakSaleLabel" text="Rs. 0" styleClass="stat-card-value"/>
                            </VBox>
                        </HBox>

                        <VBox spacing="12" VBox.vgrow="ALWAYS" style="-fx-background-color: rgba(255,255,255,0.03); -fx-background-radius: 10; -fx-padding: 15;">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Region style="-fx-background-color: #3b82f6; -fx-min-width: 4; -fx-min-height: 18; -fx-background-radius: 2;"/>
                                <Text text="Detailed Summary" style="-fx-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                            </HBox>
                            <Label fx:id="summaryLabel" text="Generate a report to view performance details." 
                                   styleClass="text-muted" wrapText="true" style="-fx-font-size: 14px; -fx-line-spacing: 5;"/>
                        </VBox>
                    </VBox>
                </HBox>
            </VBox>
        </Tab>

        <!-- MONTHLY REPORT TAB -->
        <Tab text="Monthly Report">
            <VBox spacing="20" style="-fx-padding: 15 0 0 0;">
                <!-- Monthly Stats -->
                <HBox spacing="15">
                    <VBox styleClass="stat-card,stat-card-blue" HBox.hgrow="ALWAYS" spacing="5">
                        <Label text="Total Sales" styleClass="stat-card-title"/>
                        <Label fx:id="monthlyTotalSales" text="Rs. 0" styleClass="stat-card-value"/>
                    </VBox>
                    <VBox styleClass="stat-card,stat-card-red" HBox.hgrow="ALWAYS" spacing="5">
                        <Label text="Total Returns" styleClass="stat-card-title"/>
                        <Label fx:id="monthlyTotalReturns" text="Rs. 0" styleClass="stat-card-value"/>
                    </VBox>
                    <VBox styleClass="stat-card,stat-card-green" HBox.hgrow="ALWAYS" spacing="5">
                        <Label text="Net Revenue" styleClass="stat-card-title"/>
                        <Label fx:id="monthlyNetRevenue" text="Rs. 0" styleClass="stat-card-value"/>
                    </VBox>
                    <VBox styleClass="stat-card,stat-card-purple" HBox.hgrow="ALWAYS" spacing="5">
                        <Label text="Avg. Daily Sales" styleClass="stat-card-title"/>
                        <Label fx:id="monthlyAvgDaily" text="Rs. 0" styleClass="stat-card-value"/>
                    </VBox>
                </HBox>

                <HBox spacing="20" VBox.vgrow="ALWAYS">
                    <!-- Category Breakdown -->
                    <VBox styleClass="section-panel" prefWidth="320" spacing="15">
                        <Text text="Category Breakdown" styleClass="section-title"/>
                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                            <VBox fx:id="categoryBreakdownBox" spacing="12"/>
                        </ScrollPane>
                    </VBox>

                    <!-- Top Products Cards -->
                    <VBox styleClass="section-panel" HBox.hgrow="ALWAYS" spacing="15">
                        <HBox alignment="CENTER_LEFT">
                            <Text text="Top Selling Products" styleClass="section-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="This Month" styleClass="text-muted,text-sm"/>
                        </HBox>
                        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                            <FlowPane fx:id="topProductsGrid" hgap="15" vgap="15" style="-fx-padding: 5;"/>
                        </ScrollPane>
                    </VBox>
                </HBox>
            </VBox>
        </Tab>
    </TabPane>
</VBox>
