<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<HBox xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ui.ReturnsController"
      spacing="20"
      styleClass="pos-container"
      stylesheets="@style.css">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <VBox HBox.hgrow="ALWAYS" spacing="16">
        <VBox spacing="3">
            <Text text="Return Item Process" styleClass="page-title"/>
            <Text text="Find a completed bill, choose return quantities, and confirm the refund." styleClass="page-subtitle"/>
        </VBox>

        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="return-search-bar">
            <TextField fx:id="billSearchField"
                       promptText="Enter Bill ID..."
                       HBox.hgrow="ALWAYS"
                       styleClass="search-field"/>
            <Button text="Search Bill" onAction="#handleSearchBill" styleClass="btn-primary-small"/>
            <Button text="Reset" onAction="#handleReset" styleClass="btn-hold" minWidth="82"/>
        </HBox>

        <VBox fx:id="billInfoBox" styleClass="return-bill-card" spacing="14" visible="false" managed="false">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Text text="Found Bill" styleClass="section-title"/>
                    <Label text="Review the sale before choosing items to return." styleClass="text-muted"/>
                </VBox>
                <Label fx:id="billIdLabel" text="" styleClass="return-bill-id"/>
            </HBox>

            <HBox spacing="14">
                <VBox spacing="3" HBox.hgrow="ALWAYS" styleClass="return-metric-card">
                    <Label text="Date" styleClass="inv-card-field-label"/>
                    <Label fx:id="billDateLabel" text="" styleClass="return-metric-value"/>
                </VBox>
                <VBox spacing="3" HBox.hgrow="ALWAYS" styleClass="return-metric-card">
                    <Label text="Total" styleClass="inv-card-field-label"/>
                    <Label fx:id="billTotalLabel" text="" styleClass="return-metric-value-strong"/>
                </VBox>
                <VBox spacing="3" HBox.hgrow="ALWAYS" styleClass="return-metric-card">
                    <Label text="Cashier" styleClass="inv-card-field-label"/>
                    <Label fx:id="billCashierLabel" text="" styleClass="return-metric-value"/>
                </VBox>
            </HBox>
        </VBox>

        <HBox alignment="CENTER_LEFT" spacing="10">
            <Text text="Bill Products" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="itemCountLabel" text="Search for a bill" styleClass="text-muted"/>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <FlowPane fx:id="billItemsFlow" hgap="14" vgap="14" style="-fx-padding: 2;"/>
        </ScrollPane>
    </VBox>

    <VBox prefWidth="395" spacing="15" styleClass="bill-panel">
        <VBox spacing="3">
            <Text text="Return Summary" styleClass="section-title"/>
            <Label text="Only products with a return quantity above zero are included." styleClass="text-muted"/>
        </VBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;"
                    prefHeight="315">
            <VBox fx:id="selectedReturnsBox" spacing="10" style="-fx-padding: 2;"/>
        </ScrollPane>

        <VBox spacing="12"
              style="-fx-border-color: rgba(255,255,255,0.06); -fx-border-width: 1 0 0 0; -fx-padding: 15 0 0 0;">
            <VBox spacing="5">
                <Label text="Reason" styleClass="bill-label"/>
                <TextField fx:id="reasonField"
                           promptText="Damaged, wrong item, expired..."
                           styleClass="dark-input"/>
            </VBox>

            <HBox alignment="CENTER_LEFT">
                <Label text="Refund Amount" styleClass="return-refund-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="refundLabel" text="Rs. 0.00" styleClass="return-refund-value"/>
            </HBox>

            <Button text="Process Return"
                    onAction="#handleProcessReturn"
                    maxWidth="Infinity"
                    styleClass="btn-process-return"/>
        </VBox>
    </VBox>
</HBox>
