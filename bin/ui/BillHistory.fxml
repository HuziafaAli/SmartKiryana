<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ui.BillHistoryController"
      spacing="20"
      styleClass="inventory-container">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Text text="Transaction History" styleClass="page-title"/>
    </HBox>

    <!-- Filters -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <VBox spacing="5">
            <Label text="Date Range" styleClass="text-muted,text-sm"/>
            <HBox spacing="8">
                <DatePicker fx:id="dateFrom" promptText="From" prefWidth="140" styleClass="dark-datepicker"/>
                <DatePicker fx:id="dateTo" promptText="To" prefWidth="140" styleClass="dark-datepicker"/>
            </HBox>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField" promptText="Search Bill #, Customer..." prefWidth="250" styleClass="search-field"/>
        <Button text="Filter" onAction="#handleFilter" styleClass="btn-primary-small"/>
        <Button text="Reset" onAction="#handleReset" styleClass="btn-hold"/>
    </HBox>

    <!-- Stat Cards -->
    <HBox spacing="15">
        <VBox styleClass="stat-card,stat-card-blue" HBox.hgrow="ALWAYS">
            <Label text="Total Sales" styleClass="stat-card-title"/>
            <Label fx:id="totalSalesLabel" text="Rs. 0" styleClass="stat-card-value" style="-fx-font-size: 22px;"/>
        </VBox>
        <VBox styleClass="stat-card,stat-card-green" HBox.hgrow="ALWAYS">
            <Label text="Total Orders" styleClass="stat-card-title"/>
            <Label fx:id="totalOrdersLabel" text="0" styleClass="stat-card-value" style="-fx-font-size: 22px;"/>
        </VBox>
        <VBox styleClass="stat-card,stat-card-purple" HBox.hgrow="ALWAYS">
            <Label text="Average Order Value" styleClass="stat-card-title"/>
            <Label fx:id="avgOrderLabel" text="Rs. 0" styleClass="stat-card-value" style="-fx-font-size: 22px;"/>
        </VBox>
    </HBox>

    <TabPane fx:id="historyTabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS" styleClass="inventory-tabs">
        <Tab text="Sales">
            <VBox spacing="10" style="-fx-padding: 10 0 0 0;">
                <HBox alignment="CENTER_LEFT">
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="salesCountLabel" text="0 records" styleClass="text-muted"/>
                </HBox>
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <FlowPane fx:id="billGrid" hgap="18" vgap="18" style="-fx-padding: 4 2 10 2;"/>
                </ScrollPane>
            </VBox>
        </Tab>
        <Tab text="Returns">
            <VBox spacing="10" style="-fx-padding: 10 0 0 0;">
                <HBox alignment="CENTER_LEFT">
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="returnsCountLabel" text="0 records" styleClass="text-muted"/>
                </HBox>
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <FlowPane fx:id="returnsGrid" hgap="18" vgap="18" style="-fx-padding: 4 2 10 2;"/>
                </ScrollPane>
            </VBox>
        </Tab>
    </TabPane>
</VBox>
